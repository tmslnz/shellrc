configure_git() {
	maybe_echo "configure_git()"
	command -v git > /dev/null || return 1
	CONFIGFILE=~/.gitconfig
	{ CONFIG=$(cat) ; } <<-EOF
		; BEGIN_SHELLRC

		[core]

		excludesfile = ~/.gitignore
		attributesfile = ~/.gitattributes
		# Treat spaces before tabs, lines that are indented with 8 or more spaces, and all kinds of trailing whitespace as an error
		whitespace = space-before-tab,trailing-space
		editor = nano
		quotepath = false
		# Autosave & Versions on OSX screw around with rebase workflow
		# http://www.git-tower.com/blog/make-git-rebase-safe-on-osx/
		trustctime = false
		autocrlf = false
		# safecrlf = true

		[color]

		# Use colors in Git commands that are capable of colored output when outputting to the terminal
		ui = auto

		[merge]

		# Include summaries of merged commits in newly created merge commit messages
		log = true

		[push]

		default = simple

		[credential]

		helper = cache --timeout=3600

		[alias]

		# View the SHA, description, and history graph of the latest 20 commits
		l = log --pretty=oneline -n 20 --graph
		# View the current working tree status using the short format
		s = status -s
		# Show the diff between the latest commit and the current state
		d = !"git diff-index --quiet HEAD -- || clear; git diff --patch-with-stat"
		# git di \$number shows the diff between the state \$number revisions ago and the current state
		di = !"d() { git diff --patch-with-stat HEAD~$1; }; git diff-index --quiet HEAD -- || clear; d"
		# Pull in remote changes for the current repository and all its submodules
		pullall = !"git pull; git submodule foreach git pull origin master"
		cloneall = clone --recursive
		# Commit all changes
		ca = !git add -A && git commit -av
		# Switch to a branch, creating it if necessary
		go = checkout -B
		# Show verbose output about tags, branches or remotes
		tags = tag -l
		branches = branch -a
		remotes = remote -v
		# Credit an author on the latest commit
		credit = "!f() { git commit --amend --author \"\$1 <\$2>\" -C HEAD; }; f"
		# Interactive rebase with the given number of latest commits
		rebasen = "!r() { git rebase -i HEAD~\$1; }; r"
		undopush = push -f origin HEAD^:master

		; END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_prepend_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	CONFIGFILE=~/.gitignore
	{ CONFIG=$(cat) ; } <<-EOF
		# BEGIN_SHELLRC

		# OS generated files #
		######################
		.DS_Store
		.DS_Store?
		._*
		.Spotlight-V100
		.Trashes
		ehthumbs.db
		Thumbs.db

		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_prepend_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	CONFIGFILE=~/.gitattributes
	{ CONFIG=$(cat) ; } <<-EOF
		# BEGIN_SHELLRC

		Package Control.sublime-settings -text

		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_prepend_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	unset CONFIG CONFIGFILE
}

configure_wget() {
	command -v wget > /dev/null || return 1
	if [ -z "$XDG_CONFIG_HOME" ]; then
		CONFIGFILE=~/.wgetrc
		HSTSFILE=~/.wget-hsts
	else
		mkdir -p "$XDG_CONFIG_HOME/wget"
		CONFIGFILE=$XDG_CONFIG_HOME/wget/wgetrc
		HSTSFILE=$XDG_CONFIG_HOME/wget/wget-hsts
	fi
	maybe_local_encoding() {
		if wget --help | grep -q "local-encoding"; then
		    printf "local_encoding = UTF-8"
		fi
	}
	if wget --help | grep -q "hsts"; then
		alias wget="wget --config '$CONFIGFILE' --hsts-file '$HSTSFILE'"
	fi
	{ CONFIG=$(cat) ; } <<-EOF
		# BEGIN_SHELLRC

		# https://www.gnu.org/software/wget/manual/html_node/Wgetrc-Commands.html#Wgetrc-Commands
		timestamping = on
		no_parent = on
		timeout = 60
		tries = 3
		retry_connrefused = on
		trust_server_names = on
		follow_ftp = on
		adjust_extension = on
		# http://unix.stackexchange.com/q/34730/6040
		$(maybe_local_encoding)
		robots = off
		server_response = on
		user_agent = Mozilla/5.0 (compatible; MSIE 9.0; Windows NT 6.1; Trident/5.0)

		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_prepend_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	unset CONFIG CONFIGFILE HSTSFILE
	unset -f maybe_local_encoding
}

