# shellcheck disable=SC2317
load_python_autovenv() {
	maybe_echo "load_python_autovenv()"
	# From:
	#   https://github.com/RaytingSec/autovenv/blob/master/.py_autovenv
	# Also worth looking at:
	#   https://github.com/hyperupcall/autoenv
	venv_candidates() {
		echo "$1/.venv"
		echo "$1/.env"
	}
	venv_find() {
		local venv_root=${1:-"."}
		local venv_found=""
		for (( i=10; i > 0; i-- )); do
			local venv_real=$(cd "$venv_root" && pwd -P)
			local venv_name=$(basename "$venv_real")
			for candidate in $( venv_candidates "$venv_real" ) ; do
				if [ -f "$candidate/bin/activate" ]; then
					echo "$(cd "$candidate" && pwd -P)"
					return
				fi
			done

			if [ "$venv_real" = "/" ]; then
				break
			fi
			venv_root=$venv_root/".."
		done
	}
	venv_curr() {
		if [ -n "$VIRTUAL_ENV" ] && [ "$(type -t deactivate)" = 'function' ]; then
			echo "$VIRTUAL_ENV"
		fi
	}
	venv_auto() {
		venv_new="$(venv_find)"
		venv_old="$(venv_curr)"
		if [ -z "$venv_new" ] && [ -n "$venv_old" ]; then
			echo "Deactivating $(_venv_name "$venv_old")..."
			deactivate
		elif [ -n "$venv_new" ] && [ "$venv_new" != "$venv_old" ]; then
			echo "Activating $(_venv_name "$venv_new")..."
			. "$venv_new"/bin/activate
		fi
	}
	_venv_ps1() {
		if [[ -z "$VIRTUAL_ENV" ]]; then
			printf ""
		else
			printf "%s" "$(basename "$(dirname "$(venv_curr)")")"
		fi
	}
	_venv_name() {
		printf "%s" "$(basename "$(dirname "$1")")"
	}
}

