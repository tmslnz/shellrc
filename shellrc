#!/usr/bin/env sh
# Cross-shell rc file
# sourced by
#  ~/.bash_profile
#  ~/.bashrc
#  ~/.zprofile
#  ~/.zshrc
#  ~/.profile

SHELLRC_DEBUG=false

# Prevent sourcing more than once per session
if [ "$SHELLRC_SOURCED" ]; then return 0; fi
SHELLRC_SOURCED=true

maybe_echo() {
	[ -z $SHELLRC_DEBUG ] && return 0
	[ $SHELLRC_DEBUG = true ] && echo "$1"
}

maybe_echo "$HOME/.shellrc"

is_darwin() {
	case $(uname) in
		"Darwin"*) return 0;;
		*) return 1;;
	esac
}

is_linux() {
	case $(uname) in
		"Linux"*) return 0;;
		*) return 1;;
	esac
}

is_bash() {
	[ -z "$BASH_VERSION" ] && return 1
	return 0
}

is_zsh() {
	[ -z "$ZSH_VERSION" ] && return 1
	return 0
}

snapshot_if_diff() {
	if [ -z "$2" ]; then
		echo "snapshot_if_diff(): ERROR: nothing to diff"
		return 1
	fi
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	if ! diff -EBq "$1" "$2" &>/dev/null; then
		echo "... writing $1"
		mv "$1" "$1-$TS" 2>/dev/null
		cat "$2" > "$1"
		unset TS
		return 0
	fi
	unset TS	
	return 1
}

update_shellrc() {
	# https://stackoverflow.com/questions/24118224/how-to-make-asynchronous-function-calls-in-shell-scripts
	F=$(mktemp)
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	# utc seconds: date "+%s"
	# file modfied time: date -r <filename> "+%s"
	# Find real .shellrc file if symlinked
	SHELLRC_FILE=~/.shellrc
	if command -v perl > /dev/null 2>&1; then
		SHELLRC_FILE=$(perl -MCwd -le 'print Cwd::abs_path(shift)' "$SHELLRC_FILE")
	elif command -v realpath > /dev/null 2>&1; then
		SHELLRC_FILE=$(realpath "$SHELLRC_FILE")
	else
		SHELLRC_FILE=$(readlink -f "$SHELLRC_FILE")
	fi
	curl -s -L -o "$F" https://raw.githubusercontent.com/tmslnz/shellrc/main/shellrc
	if ! diff -EBq "$SHELLRC_FILE" "$F" &>/dev/null; then
		echo "... writing $SHELLRC_FILE"
		mv "$SHELLRC_FILE" "$SHELLRC_FILE-$TS" 2>/dev/null
		cat "$F" > "$SHELLRC_FILE"
	else
		echo "... no updates available"
	fi
	unset TS F
}

install_sh() {
	is_bash || is_zsh && return 0
	maybe_echo "install_sh()"
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	FILES="$HOME/.profile"
	for F in ${FILES}; do
		if [ -f "$F" ] && sed '2!d' "$F" | grep -Fq '[ -f ~/.shellrc ]'; then
			continue
		else
			[ -f "$F" ] && mv "$F" "$F-$TS"
			tee "$F" <<-EOF >/dev/null
				#!/usr/bin/env sh
				[ -f ~/.shellrc ] && source ~/.shellrc
				EOF
		fi
	done
	unset TS FILES F
}

install_bash() {
	is_bash || return 0
	maybe_echo "install_bash()"
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	FILES=("$HOME/.bash_profile" "$HOME/.bashrc")
	for F in "${FILES[@]}"; do
		if [ -f "$F" ] && sed '2!d' "$F" | grep -Fq '[ -f ~/.shellrc ]'; then
			continue
		else
			[ -f "$F" ] && mv "$F" "$F-$TS"
			tee "$F" <<-EOF >/dev/null
				#!/usr/bin/env bash
				[ -f ~/.shellrc ] && source ~/.shellrc
				EOF
		fi
	done
	unset TS FILES F
}

enable_homebrew_bash() {
	command -v brew > /dev/null 2>&1 || return 0
	BREW_PREFIX=$(brew --prefix)
	grep -Fxq "$BREW_PREFIX/bin/bash" /etc/shells && return 0
	[ -f "$BREW_PREFIX/bin/bash" ] || return 0
	maybe_echo "enable_homebrew_bash()"
	echo "$BREW_PREFIX/bin/bash" | sudo tee -a /etc/shells
	sudo chsh -s "$BREW_PREFIX/bin/bash"
	cat /etc/shells
	unset BREW_PREFIX
}

disable_homebrew_bash() {
	command -v brew > /dev/null 2>&1 || return 0
	grep -Fxq "$(brew --prefix)/bin/bash" /etc/shells && return 0
	maybe_echo "disable_homebrew_bash()"
	sudo chsh -s /bin/bash
}

install_zsh() {
	is_zsh || return 0
	maybe_echo "install_zsh()"
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	# FILES=("$HOME/.zprofile" "$HOME/.zshrc")
	FILES=("$HOME/.zshrc") # Seems to be setting only from here
	for F in "${FILES[@]}"; do
		if [ -f "$F" ] && sed '2!d' "$F" | grep -Fq '[ -f ~/.shellrc ]'; then
			continue
		else
			[ -f "$F" ] && mv "$F" "$F-$TS"
			tee "$F" <<-EOF >/dev/null
				#!/usr/bin/env zsh
				[ -f ~/.shellrc ] && source ~/.shellrc
				EOF
		fi
	done
	unset TS FILES F
}

