	fi
	if [ -z "$XDG_CACHE_HOME" ]; then
		mkdir -p "$HOME/.cache"
		export XDG_CACHE_HOME="$HOME/.cache"
	fi
	if [ -z "$XDG_DATA_HOME" ]; then
		mkdir -p "$HOME/.local/share"
		export XDG_DATA_HOME="$HOME/.local/share"
	fi
	if [ -z "$XDG_STATE_HOME" ]; then
		mkdir -p "$HOME/.local/state"
		export XDG_STATE_HOME="$HOME/.local/state"
	fi
	# See https://wiki.archlinux.org/title/XDG_Base_Directory
	# XDG_RUNTIME_DIR
	# XDG_DATA_DIRS
	# XDG_CONFIG_DIRS
}

is_smart_terminal() {
	case "$TERM" in
		"dumb")
			return 1;;
		xterm*|rxvt*|eterm*|screen*)
			return 0;;
		*)
			return 1;;
	esac
}

set_bash_prompt_string() {
	maybe_echo "set_bash_prompt_string()"
	if ! is_smart_terminal; then
		PS1="> "
		return 0
	fi
	PS1=$'\[\e[1m\]\u\[\e[2m\]@\h\[\e[0;2m\]:\[\e[0m\]\w\[\e[2m\] \xe2\x97\x8f \[\e[0m\]'
}

set_zsh_prompt_string() {
	maybe_echo "set_zsh_prompt_string()"
	if ! is_smart_terminal; then
		PS1="> "
		return 0
	fi
	PROMPT=$'%B%n%{\e[2m%}@%m%{\e[0;2m%}:%{\e[0m%}%~%{\e[2m%} \xe2\x97\x8f %{\e[0m%}'
}

