		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_prepend_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	if is_bash; then
		bind -f "$CONFIGFILE"
	fi
	unset CONFIG CONFIGFILE
}

