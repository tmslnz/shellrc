#!/usr/bin/env sh
# shellcheck disable=SC1090,SC1091
# Cross-shell rc file
# sourced by
#  ~/.bash_profile
#  ~/.bashrc
#  ~/.zprofile
#  ~/.zshrc
#  ~/.profile

# SHELLRC_DEBUG=true

# Prevent sourcing more than once per session
if [ "$SHELLRC_SOURCED" ]; then return 0; fi
SHELLRC_SOURCED=true

maybe_echo() {
	[ -z "$SHELLRC_DEBUG" ] && return 0
	[ "$SHELLRC_DEBUG" = true ] && echo "$1"
}

maybe_echo "$HOME/.shellrc"

is_darwin() {
	uname | awk '!/[Dd]arwin/{exit 1}'
}

is_linux() {
	uname | awk '!/[Ll]inux/{exit 1}'
}

is_bash() {
	[ -z "$BASH_VERSION" ] && return 1 || return 0
}

is_zsh() {
	[ -z "$ZSH_VERSION" ] && return 1 || return 0
}

_rename_with_timestamp() {
	maybe_echo "_rename_with_timestamp()"
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	mv "$1" "$1-$TS" > /dev/null 2>&1
	unset TS
}

_prepend_section_in_file() {
	maybe_echo "_prepend_section_in_file()"
	_SECTION="$1"
	_FILE="$2"
	[ -f "$_FILE" ] || return 1
	_SECTION_READ=$(awk '/BEGIN_SHELLRC/,/END_SHELLRC/{print $0}' "$_FILE")
	if [ -z "$_SECTION_READ" ]; then
		printf '%s\n%s\n' "$_SECTION" "$(cat "$_FILE")" > "$_FILE"
	fi
	unset _SECTION _FILE _SECTION_READ
}

_append_section_in_file() {
	maybe_echo "_append_section_in_file()"
	_SECTION="$1"
	_FILE="$2"
	[ -f "$_FILE" ] || return 1
	_SECTION_READ=$(awk '/BEGIN_SHELLRC/,/END_SHELLRC/{print $0}' "$_FILE")
	if [ -z "$_SECTION_READ" ]; then
		printf '%s\n%s\n' "$(cat "$_FILE")" "$_SECTION" > "$_FILE"
	fi
	unset _SECTION _FILE _SECTION_READ
}

_update_section_in_file() {
	maybe_echo "_update_section_in_file()"
	_SECTION="$1"
	_FILE="$2"
	[ -f "$_FILE" ] || return 1
	# Read current from disk
	_SECTION_READ=$(awk '/BEGIN_SHELLRC/,/END_SHELLRC/{print $0}' "$_FILE")
	# Abort if: no SHELLRC section is found
	if [ -z "$_SECTION_READ" ]; then
		maybe_echo "... $_FILE has no SHELLRC section. Aborting."
		return 0
	# Abort if: SHELLRC section is unchanged
	elif [ "$_SECTION_READ" = "$_SECTION" ]; then
		maybe_echo "... SHELLRC section in $_FILE is unchanged."
		return 0
	# Abort if: destination is newer than .shellrc
	elif [ "$(date -r "$_FILE" "+%s")" -gt "$(date -r "$(_get_shellrc_file)" "+%s")" ]; then
		maybe_echo "... SHELLRC section in $_FILE has recent edits. Aborting."
		return 0
	fi
	maybe_echo "... updating SHELLRC section in $_FILE"
	# Finally replace ssh config section with our section
	_TEMPFILE="$(mktemp)"
	awk '
		BEGIN { sv=ARGV[1]; delete ARGV[1] }
		/BEGIN_SHELLRC/ { print sv; section=1; next }
		/END_SHELLRC/ { section=0; next }
		section {next}
		{print}
	' "$_SECTION" "$_FILE" > "$_TEMPFILE" && mv "$_TEMPFILE" "$_FILE"
	unset _SECTION _SECTION_READ _FILE _TEMPFILE
}

_get_shellrc_file() {
	SHELLRC_FILE=~/.shellrc
	if command -v perl > /dev/null; then
		SHELLRC_FILE=$(perl -MCwd -le 'print Cwd::abs_path(shift)' "$SHELLRC_FILE")
	elif command -v realpath > /dev/null; then
		SHELLRC_FILE=$(realpath "$SHELLRC_FILE")
	else
		SHELLRC_FILE=$(readlink -f "$SHELLRC_FILE")
	fi
	printf "%s" "$SHELLRC_FILE"
	unset SHELLRC_FILE
}

update_shellrc() {
	# https://stackoverflow.com/questions/24118224/how-to-make-asynchronous-function-calls-in-shell-scripts
	F=$(mktemp)
	# utc seconds: date "+%s"
	# file modfied time: date -r <filename> "+%s"
	# Find real .shellrc file if symlinked
	SHELLRC_FILE=$(_get_shellrc_file)
	if ! curl -s -L -o "$F" https://raw.githubusercontent.com/tmslnz/shellrc/main/shellrc; then
		echo "... curl error"
		return 1
	fi
	if ! diff -EBq "$SHELLRC_FILE" "$F" &>/dev/null; then
		echo "... writing $SHELLRC_FILE"
		_rename_with_timestamp "$SHELLRC_FILE"
		cat "$F" > "$SHELLRC_FILE"
		. "$SHELLRC_FILE"
	else
		echo "... no updates available"
	fi
	unset F SHELLRC_FILE
}

setup_sh() {
	is_bash || is_zsh && return 0
	maybe_echo "setup_sh()"
	CONFIGFILE=$HOME/.profile
	{ CONFIG=$(cat) ; } <<-'EOF'
		# BEGIN_SHELLRC
		[ -f ~/.shellrc ] && . ~/.shellrc
		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_append_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	unset CONFIG CONFIGFILE
}

setup_bash() {
	is_bash || return 0
	maybe_echo "setup_bash()"
	if [ "$BASH_VERSINFO" -lt 4 ]; then
		echo "You are using a very old version of Bash: $BASH_VERSION"
		if is_darwin && command -v brew > /dev/null; then
			echo "Run:"
			echo "$ brew install bash"
			echo "$ enable_homebrew_bash"
		elif is_darwin; then
			echo "$ Please install \"Homebrew\" from https://brew.sh"
			echo "$ enable_homebrew_bash"
		else
			echo "Please update Bash"
		fi
		echo "To silence this message add this to your ~.bashrc"
		echo "export SILENCE_SHELLRC_WARNINGS=true"
	fi
	CONFIGFILE=$HOME/.bash_profile
	{ CONFIG=$(cat) ; } <<-'EOF'
		# BEGIN_SHELLRC
		[ -f /etc/bashrc ] && . /etc/bashrc
		[ -f ~/.shellrc ] && . ~/.shellrc
		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_append_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	CONFIGFILE=$HOME/.bashrc
	{ CONFIG=$(cat) ; } <<-'EOF'
		# BEGIN_SHELLRC
		[ -f /etc/bashrc ] && . /etc/bashrc
		SHELLRC_DEBUG=false
		[ -f ~/.shellrc ] && . ~/.shellrc
		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_append_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	unset CONFIG CONFIGFILE
}

enable_homebrew_bash() {
	command -v brew > /dev/null || return 0
	BREW_PREFIX=$(brew --prefix)
	grep -Fxq "$BREW_PREFIX/bin/bash" /etc/shells && return 0
	[ -f "$BREW_PREFIX/bin/bash" ] || return 0
	maybe_echo "enable_homebrew_bash()"
	echo "$BREW_PREFIX/bin/bash" | sudo tee -a /etc/shells
	sudo chsh -s "$BREW_PREFIX/bin/bash"
	cat /etc/shells
	unset BREW_PREFIX
}

disable_homebrew_bash() {
	command -v brew > /dev/null || return 0
	grep -Fxq "$(brew --prefix)/bin/bash" /etc/shells && return 0
	maybe_echo "disable_homebrew_bash()"
	sudo chsh -s /bin/bash
}

setup_zsh() {
	is_zsh || return 0
	maybe_echo "setup_zsh()"
	CONFIGFILE=$HOME/.zshrc
	{ CONFIG=$(cat) ; } <<-'EOF'
		# BEGIN_SHELLRC
		[ -f ~/.shellrc ] && . ~/.shellrc
		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_append_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	unset CONFIG CONFIGFILE
}

configure_darwin() {
	is_darwin || return 0
	maybe_echo "configure_darwin()"
	export SHELL_SESSIONS_DISABLE=1
	export SHELL_SESSIONS_HISTORY=0
	export BASH_SILENCE_DEPRECATION_WARNING=1
}

configure_linux() {
	is_linux || return 0
	maybe_echo "configure_linux()"
}

set_shell_options() {
	maybe_echo "set_shell_options()"
	[ -f "$HOME/.hushlogin" ] || touch "$HOME/.hushlogin"
}

# shellcheck disable=SC3044
set_bash_options() {
	is_bash || return 0
	maybe_echo "set_bash_options()"
	HISTIGNORE="&:[ ]*:cd ~:~:cd ..:..:clear:history:[bf]g:reboot:shutdown:exit:date:pwd:* --help"
	HISTCONTROL="erasedups:ignorespace"
	HISTSIZE=32768
	HISTFILESIZE=$HISTSIZE
	SAVEHIST=$HISTSIZE
	HISTFILE="${HOME}/.history"
	# Use standard ISO 8601 timestamp
	# %F equivalent to %Y-%m-%d
	# %T equivalent to %H:%M:%S (24-hours format)
	# HISTTIMEFORMAT='%F %T '
	# Prevent file overwrite on stdout redirection
	# Use `>|` to force redirection to an existing file
	# set -o noclobber
	# Update window size after every command
	shopt -s checkwinsize
	# Automatically trim long paths in the prompt (requires Bash 4.x)
	PROMPT_DIRTRIM=2
	# Turn on recursive globbing (enables ** to recurse all directories)
	shopt -s globstar 2> /dev/null
	# Case-insensitive globbing (used in pathname expansion)
	shopt -s nocaseglob;
	# Append to the history file, don't overwrite it
	shopt -s histappend
	# Save multi-line commands as one command
	shopt -s cmdhist
	# Prepend cd to directory names automatically
	shopt -s autocd 2> /dev/null
	# Correct spelling errors during tab-completion
	shopt -s dirspell 2> /dev/null
	# Correct spelling errors in arguments supplied to cd
	shopt -s cdspell 2> /dev/null
	# This defines where cd looks for targets
	# Add the directories you want to have fast access to, separated by colon
	# Ex: CDPATH=".:~:~/projects" will look for targets in the current working directory, in home and in the ~/projects folder
	CDPATH="."
	# This allows you to bookmark your favorite places across the file system
	# Define a variable containing a path and you will be able to cd into it regardless of the directory you're in
	shopt -s cdable_vars
	# Examples:
	# export dotfiles="$HOME/dotfiles"
	# export projects="$HOME/projects"
	# export documents="$HOME/Documents"
	# export dropbox="$HOME/Dropbox"
}

# shellcheck disable=SC2034
set_zsh_options() {
	is_zsh || return 0
	maybe_echo "set_zsh_options()"
	# https://zsh.sourceforge.io/Doc/Release/Options.html
	# setopt extended_history       # record timestamp of command in HISTFILE
	setopt hist_expire_dups_first # delete duplicates first when HISTFILE size exceeds HISTSIZE
	setopt hist_ignore_all_dups
	setopt hist_ignore_space      # ignore commands that start with space
	setopt hist_verify            # show command with history expansion to user before running it
	setopt inc_append_history     # add commands to HISTFILE in order of execution
	# setopt share_history          # share command history data
	setopt hash_list_all
	setopt correct
	# unsetopt extended_history
	HISTORY_IGNORE="(&|[ ]*|cd ~|~|cd ..|..|clear|history|[bf]g|reboot|shutdown|exit|date|pwd|* --help)"
	HISTFILE="${HOME}/.history"
	HISTSIZE=50000
	SAVEHIST=10000
	ZSH_COMPDUMP="$XDG_CACHE_HOME/.zcompdump-$HOST"
}

set_xdg_directories() {
	maybe_echo "set_xdg_directories()"
	if [ -z "$XDG_CONFIG_HOME" ]; then
		mkdir -p "$HOME/.config"
		export XDG_CONFIG_HOME="$HOME/.config"
	fi
	if [ -z "$XDG_CACHE_HOME" ]; then
		mkdir -p "$HOME/.cache"
		export XDG_CACHE_HOME="$HOME/.cache"
	fi
	if [ -z "$XDG_DATA_HOME" ]; then
		mkdir -p "$HOME/.local/share"
		export XDG_DATA_HOME="$HOME/.local/share"
	fi
	if [ -z "$XDG_STATE_HOME" ]; then
		mkdir -p "$HOME/.local/state"
		export XDG_STATE_HOME="$HOME/.local/state"
	fi
	# See https://wiki.archlinux.org/title/XDG_Base_Directory
	# XDG_RUNTIME_DIR
	# XDG_DATA_DIRS
	# XDG_CONFIG_DIRS
}

is_smart_terminal() {
	maybe_echo "is_smart_terminal()"
	case "$TERM" in
		"dumb")
			return 1;;
		xterm*|rxvt*|eterm*|screen*)
			return 0;;
		*)
			return 1;;
	esac
}

set_bash_prompt_string() {
	maybe_echo "set_bash_prompt_string()"
	if ! is_smart_terminal; then
		PS1="> "
		return 0
	fi
	PS1=$'\[\e[1m\]\u\[\e[2m\]@\h\[\e[0;2m\]:\[\e[0m\]\w\[\e[2m\] \xe2\x97\x8f \[\e[0m\]'
}

set_zsh_prompt_string() {
	maybe_echo "set_zsh_prompt_string()"
	if ! is_smart_terminal; then
		PS1="> "
		return 0
	fi
	# shellcheck disable=SC2034
	PROMPT=$'%B%n%{\e[2m%}@%m%{\e[0;2m%}:%{\e[0m%}%~%{\e[2m%} \xe2\x97\x8f %{\e[0m%}'
}

set_ls_colors() {
	maybe_echo "set_ls_colors()"
	# https://geoff.greer.fm/lscolors/
	# Detect which `ls` flavor is in use
	export CLICOLOR=1 # macOS only
	if ls --color > /dev/null 2>&1; then
		LS_COLOR_FLAG="--color"
	else # OS X `ls`
		LS_COLOR_FLAG="-G"
	fi
	# shellcheck disable=SC2139
	alias ls="command ls ${LS_COLOR_FLAG}"
	# export LS_COLORS='no=00:fi=00:di=01;34:ln=01;36:pi=40;33:so=01;35:do=01;35:bd=40;33;01:cd=40;33;01:or=40;31;01:ex=01;32:*.tar=01;31:*.tgz=01;31:*.arj=01;31:*.taz=01;31:*.lzh=01;31:*.zip=01;31:*.z=01;31:*.Z=01;31:*.gz=01;31:*.bz2=01;31:*.deb=01;31:*.rpm=01;31:*.jar=01;31:*.jpg=01;35:*.jpeg=01;35:*.gif=01;35:*.bmp=01;35:*.pbm=01;35:*.pgm=01;35:*.ppm=01;35:*.tga=01;35:*.xbm=01;35:*.xpm=01;35:*.tif=01;35:*.tiff=01;35:*.png=01;35:*.mov=01;35:*.mpg=01;35:*.mpeg=01;35:*.avi=01;35:*.fli=01;35:*.gl=01;35:*.dl=01;35:*.xcf=01;35:*.xwd=01;35:*.ogg=01;35:*.mp3=01;35:*.wav=01;35:'
	unset LS_COLOR_FLAG
}

make_aliases() {
	maybe_echo "make_aliases()"
	is_available() {
		command -v "$1" > /dev/null
	}
	if ! type _get_comp_words_by_ref > /dev/null 2>&1; then
		alias sudo='sudo ' # Enable sudo <alias>, only if bash-completion is not loaded.
	fi
	alias lsd="ls -la \${LS_COLOR_FLAG} | grep '^d'" # List only directories
	is_available nano && alias crontab="EDITOR=nano crontab" # Reset EDITOR for crontab
	is_available dscacheutil && alias flushdns="dscacheutil -flushcache && killall -HUP mDNSResponder"
	is_available dig && alias publicip="dig +short myip.opendns.com @resolver1.opendns.com"
	if ! is_available pgrep; then
		# shellcheck disable=SC2317,SC2009
		psgrep () {
			ps aux | grep -Ev grep | grep "$1" | awk '{print $2}'
		}
	fi
	is_available ip && alias localip="ip route get 1 | awk '{print \$NF;exit}'"
	is_available ipconfig && alias localip="ipconfig getifaddr en0"
	alias ips="ifconfig | sed -En 's/127.0.0.1//;s/.*inet (addr:)?(([0-9]*\.){3}[0-9]*).*/\2/p'"
	# macOS fallbacks
	! is_available md5sum && alias md5sum="md5"
	! is_available sha1sum && alias sha1sum="shasum"
	is_darwin && alias dsstore="find . -type f -name '*.DS_Store' -ls -delete"
	# Docker container aliases
	if is_available docker; then
		alias photostructure="docker exec -u photostructure -it photostructure ./photostructure"
	fi
	unset -f is_available
}

configure_nano() {
	command -v nano > /dev/null || return 1
	maybe_echo "configure_nano()"
	if command -v brew > /dev/null && [ -d "$(brew --prefix)/share/nanorc" ]; then
		NANORC_DIR="$(brew --prefix)/share/nanorc"
	elif command -v brew > /dev/null; then
		echo "Run:"
		echo "$ brew install nano nanorc"
	elif [ -d /usr/share/nano ]; then
		NANORC_DIR="/usr/share/nano"
	elif [ -d ~/.nano/nanorc ]; then
		NANORC_DIR=~/.nano/nanorc
	elif [ -d /usr/share/nano-syntax-highlighting ]; then
		NANORC_DIR="/usr/share/nano-syntax-highlighting"
	elif [ -d /etc/nanorc ]; then
		NANORC_DIR="/etc/nanorc"
	fi

	CONFIGFILE=~/.nanorc
	{ CONFIG=$(cat) ; } <<-EOF
		# BEGIN_SHELLRC

		set atblanks        # wrap line at blanks.
		set cutfromcursor   # CTRL+K cuts from cursor position to end of line.
		# set nohelp          # Disable the help information (CTRL+G to view the help screen).
		set softwrap        # Enable softwrap of lines.
		set tabsize 4       # Sets tab-to-spaces size to 4.
		set tabstospaces    # Converts TAB key press to spaces.
		set speller "aspell -x -c"         # Sets what spelling utility to use.
		set constantshow    # Displays useful information e.g. line number and position in the bottom bar.
		set linenumbers     # Lines are numbered.
		set casesensitive   # Case insensitive search.
		set historylog      # Save the last 100 history searches for later use.
		set positionlog     # Saves the cursor position between editing sessions.
		set zap             # Allows you to highlight text (CTRL+SHIFT+ARROW) and delete it with backspace.
		set autoindent      # A new line will have the same number of leading spaces as the previous one.
		set indicator       # Displays a scroll bar on the right that shows the position and size of the current view port.
		set minibar         # Displays file name and other information in the bottom bar. Removes top bar.

		# https://stackoverflow.com/a/74008963
		bind ^Z suspend main

		# Enables the syntax highlighting.
		include "$NANORC_DIR/*.nanorc"

		# END_SHELLRC
		EOF
	[ ! -f "$CONFIGFILE" ] && touch "$CONFIGFILE"
	_append_section_in_file "$CONFIG" "$CONFIGFILE"
	_update_section_in_file "$CONFIG" "$CONFIGFILE"
	unset CONFIG CONFIGFILE NANORC_DIR
}

