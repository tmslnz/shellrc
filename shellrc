write_inputrc() {
	maybe_echo "write_inputrc()"
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	F=$(mktemp)
	tee "$F" <<-'EOF' >/dev/null
		# Use the text that has already been typed as the prefix for searching through
		# commands (i.e. more intelligent Up/Down behavior)
		"\e[A": history-search-backward
		"\e[B": history-search-forward
		"\eOA": history-search-backward
		"\eOB": history-search-forward
		
		# Use Alt/Meta + Delete to delete the preceding word
		"\e[3;3~": kill-word

		$if Bash
		# E.g. typing !!<space> will replace the !! with your last command
		Space: magic-space
		$endif

		# Make Tab autocomplete regardless of filename case
		set completion-ignore-case on

		# List all matches in case multiple possible completions are possible
		set show-all-if-ambiguous on

		# Immediately add a trailing slash when autocompleting symlinks to directories
		set mark-symlinked-directories on

		# Do not autocomplete hidden files unless the pattern explicitly begins with a dot
		set match-hidden-files off

		# Show all autocomplete results at once
		set page-completions off

		# If there are more than 200 possible completions for a word, ask to show them all
		set completion-query-items 200

		# Show extra file information when completing, like `ls -F` does
		set visible-stats on

		# Be more intelligent when autocompleting by also looking at the text after
		# the cursor. For example, when the current line is "cd ~/src/mozil", and
		# the cursor is on the "z", pressing Tab will not autocomplete it to "cd
		# ~/src/mozillail", but to "cd ~/src/mozilla". (This is supported by the
		# Readline used by Bash 4.)
		set skip-completed-text on

		# Allow UTF-8 input and output, instead of showing stuff like $'\0123\0456'
		set input-meta on
		set output-meta on
		set convert-meta off

		# Treat hyphens and underscores as equivalent
		set completion-map-case on
		EOF
	if ! diff -EBq ~/.inputrc "$F" &>/dev/null; then
		echo "... writing $HOME/.inputrc"
		mv "$HOME/.inputrc" "$HOME/.inputrc-$TS" 2>/dev/null
		cat "$F" > ~/.inputrc
	fi
	if is_bash; then
		bind -f "$HOME/.inputrc"
	fi
	unset TS F
}

write_npmrc() {
	maybe_echo "write_npmrc()"
	if ! command -v npm >/dev/null; then return 0; fi
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	F=$(mktemp)
	export NPM_CONFIG_USERCONFIG="$XDG_CONFIG_HOME/npmrc"
	tee "$F" <<-EOF >/dev/null
		userconfig="$NPM_CONFIG_USERCONFIG"
		cache="$XDG_CACHE_HOME/npm"
		save-exact=true
		prefer-offline=true
		update-notifier=false
		omit=optional
		fund=false
		long=true
		EOF
	if ! diff -EBq \
		-I '^_.*' \
		-I '*._auth.*' \
		-I '*._pass.*' \
		-I '^username.*' \
		-I '^email.*' \
		-I '^certfile.*' \
		-I '^keyfile.*' \
		-I '^ca=.*' \
		-I '^ca\[.*' \
		-I '^init-.*' \
		"$NPM_CONFIG_USERCONFIG" "$F" &>/dev/null; then
			echo "... writing $NPM_CONFIG_USERCONFIG"
			mv "$NPM_CONFIG_USERCONFIG" "$NPM_CONFIG_USERCONFIG-$TS" 2>/dev/null
			cat "$F" > "$NPM_CONFIG_USERCONFIG"
	fi
	unset TS F
}

