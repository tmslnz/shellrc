# shellcheck disable=SC2317
load_python_autovenv() {
	maybe_echo "load_python_autovenv()"
	# Modified from:
	#   https://github.com/RaytingSec/autovenv/blob/master/.py_autovenv
	venv_auto() {
		venv_new="$(_venv_find)"
		venv_old="$(_venv_curr)"
		if [ -z "$venv_new" ] && [ -n "$venv_old" ]; then
			echo "Deactivating $(_venv_name "$venv_old")..."
			deactivate
		elif [ -n "$venv_new" ] && [ "$venv_new" != "$venv_old" ]; then
			echo "Activating $(_venv_name "$venv_new")..."
			. "${venv_new}/bin/activate"
		fi
	}
	_venv_candidates() {
		echo "$1/.venv"
		echo "$1/.env"
	}
	_venv_find() {
		venv_root=.
		j=0
		while [ "$j" -le 5 ]; do
			venv_real="$(cd "$venv_root" && pwd -P)"
			for candidate in $( _venv_candidates "$venv_real" ) ; do
				if [ -f "$candidate/bin/activate" ]; then
					cd "$candidate" && pwd -P
					return
				fi
			done
			[ "$venv_real" = "/" ] && break
			venv_root="${venv_root}/.."
			j=$(( j + 1 ))
		done
		unset venv_root venv_real candidate
	}
	_venv_curr() {
		if [ -n "$VIRTUAL_ENV" ] && [ "$(type -t deactivate)" = 'function' ]; then
			echo "$VIRTUAL_ENV"
		fi
	}
	_venv_ps1() {
		if [ -z "$VIRTUAL_ENV" ]; then
			printf ""
		else
			printf "%s" "$(basename "$(dirname "$(_venv_curr)")")"
		fi
	}
	_venv_name() {
		printf "%s" "$(basename "$(dirname "$1")")"
	}
}

