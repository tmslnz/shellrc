set_path() {
	maybe_append() {
		if [ -d "$1" ]; then export PATH="$PATH":"$1"; fi
	}
	maybe_prepend() {
		if [ -d "$1" ]; then export PATH="$1":"$PATH"; fi
	}
	# Homebrew
	if command -v brew > /dev/null; then
		BREW_PREFIX=$(brew --prefix)
		maybe_prepend "$BREW_PREFIX/bin:$BREW_PREFIX/sbin"
		maybe_prepend "$BREW_PREFIX/opt/sqlite/bin"
		maybe_prepend "$BREW_PREFIX/opt/ffmpeg@5/bin"
		maybe_prepend "$BREW_PREFIX/opt/php@8.1/bin"
		maybe_prepend "$BREW_PREFIX/opt/php@8.1/sbin"
		maybe_prepend "$BREW_PREFIX/opt/python/libexec/bin"
		maybe_prepend "$BREW_PREFIX/opt/python@3.12/bin"
		maybe_prepend "$BREW_PREFIX/usr/local/opt/automysqlbackup/sbin"
		unset BREW_PREFIX
	fi
	# Mac apps
	maybe_prepend "/Applications/Sublime Text.app/Contents/SharedSupport/bin"
	maybe_prepend "/Applications/Tower.app/Contents/MacOS"
	maybe_prepend "/Applications/VMware Fusion.app/Contents/Library"
	maybe_prepend "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
	maybe_prepend "/Applications"
	# Extra
	maybe_prepend "$HOME/.cargo/bin"
	maybe_prepend "$HOME/bin/automysqlbackup-v3.0_rc6"
	maybe_prepend "$HOME/.bun"
	# pipx
	maybe_prepend "$HOME/.local/bin"
	# Opalstack
	maybe_prepend "$HOME/local"
	if [ -d "$HOME/local" ]; then
		for D in "$HOME"/local/*/; do
			export PATH="$D:$PATH"
			maybe_prepend "$D/bin"
		done
	fi
	unset D
	unset -f maybe_prepend maybe_append
}

# shellcheck disable=SC2317
make_utility_functions() {
	wordpress_delete_thumbnails() {
		if [[ "$(pwd)" == *"/uploads"* ]]; then
			find . -regextype egrep -regex ".+-[0-9]+?x[0-9]+\.(jpe?g|png)$" -type f -print0 | xargs -0 rm
		fi
	}
	wordpress_delete_thumbnails() {
		if [[ "$(pwd)" == *"/uploads"* ]]; then
			find . -regextype egrep -regex ".+\.(jpe?g|png)$" -type f -print0 | xargs -0 mogrify -resize "3072x3072>" -quality 92
		fi
	}
}

load_bash_completion() {
	is_bash || return 0
	complete -cf sudo
	if ! [ "${BASH_VERSINFO:-0}" -ge 4 ]; then
		echo "... Bash version too old (${BASH_VERSION}); not loading completions"
		return 1
	fi
	type _get_comp_words_by_ref > /dev/null 2>&1 && return 0
	maybe_echo "load_bash_completion()"
	PATHS=(
		"$sysconfdir/profile.d/bash_completion.sh"
		"/usr/share/bash-completion/bash_completion"
		"/etc/bash_completion"
		"/sw/etc/bash_completion"
		"/usr/local/etc/bash_completion"
	)
	for P in "${PATHS[@]}"; do
		[ -f "$P" ] && maybe_echo "... $P"
		if [[ $PS1 && -f $P ]]; then
			unalias sudo > /dev/null 2>&1 # this alias clashes with bash-completion
			# shellcheck disable=SC1090
			. "$P"
			break
		fi
	done
	unset P PATHS
}

load_zsh_completion() {
	# See: https://zsh.sourceforge.io/Doc/Release/Completion-System.html#index-matcher_002dlist_002c-completion-style
	is_zsh || return 0
	maybe_echo "load_zshell_completion()"
	autoload -Uz compinit && compinit
	zstyle ':completion:*' matcher-list 'r:|?=**'
	# autoload -U +X compinit && compinit
	# zstyle ':completion:*' matcher-list \
	# 	'm:{[:lower:]}={[:upper:]}' \
	# 	'+r:|[._-]=* r:|=*' \
	# 	'+l:|=*'
}

load_python_completions() {
	# for zsh: https://stackoverflow.com/a/75791863
	maybe_echo "load_python_completions()"
	command -v 'register-python-argcomplete' > /dev/null || return 1
	load_python_completion() {
		command -v "$1" > /dev/null && eval "$(register-python-argcomplete $1)"
	}
	load_python_completion pipx
	unset -f load_python_completion
}

