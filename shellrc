make_aliases() {
	maybe_echo "make_aliases()"
	is_available() {
		if command -v "$1" > /dev/null 2>&1; then return 0; else return 1; fi
	}
	if ! type _get_comp_words_by_ref > /dev/null 2>&1; then
		alias sudo='sudo ' # Enable sudo <aslias>, only if bash-completion is not loaded.
	fi
	alias lsd="ls -la \${LS_COLOR_FLAG} | grep '^d'" # List only directories
	is_available nano && alias crontab="env EDITOR=nano crontab" # Reset EDITOR for crontab
	is_available dscacheutil && alias flushdns="dscacheutil -flushcache && killall -HUP mDNSResponder"
	is_available dig && alias publicip="dig +short myip.opendns.com @resolver1.opendns.com"
	if ! is_available pgrep; then
		psgrep () {
			ps aux | egrep -v grep | egrep $1 | awk '{print $2}'
		}
	fi
	is_darwin && alias ip="ipconfig getifaddr en0"
	alias ips="ifconfig | sed -En 's/127.0.0.1//;s/.*inet (addr:)?(([0-9]*\.){3}[0-9]*).*/\2/p'"
	# macOS fallbacks
	! is_available md5sum && alias md5sum="md5"
	! is_available sha1sum && alias sha1sum="shasum"
	is_darwin && alias dsstore="find . -type f -name '*.DS_Store' -ls -delete"
	# Docker container aliases
	if is_available docker; then
		alias photostructure="docker exec -u photostructure -it photostructure ./photostructure"
	fi
	unset -f is_available
}

