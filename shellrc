#!/usr/bin/env sh
# Cross-shell rc file
# sourced by
#  ~/.bash_profile
#  ~/.bashrc
#  ~/.zprofile
#  ~/.zshrc
#  ~/.profile

SHELLRC_DEBUG=false

# Prevent sourcing more than once per session
if [ "$SHELLRC_SOURCED" ]; then return 0; fi
SHELLRC_SOURCED=true

maybe_echo() {
	[ -z "$SHELLRC_DEBUG" ] && return 0
	[ $SHELLRC_DEBUG = true ] && echo "$1"
}

maybe_echo "$HOME/.shellrc"

# shellcheck disable=SC2317
is_darwin() {
	case $(uname) in
		"Darwin"*) return 0;;
		*) return 1;;
	esac
}

# shellcheck disable=SC2317
is_linux() {
	case $(uname) in
		"Linux"*) return 0;;
		*) return 1;;
	esac
}

# shellcheck disable=SC2317
is_bash() {
	[ -z "$BASH_VERSION" ] && return 1
	return 0
}

# shellcheck disable=SC2317
is_zsh() {
	[ -z "$ZSH_VERSION" ] && return 1
	return 0
}

_rename_with_timestamp() {
	maybe_echo "_rename_with_timestamp()"
	TS=$(date -u +"%Y-%m-%dT%H%M%S")
	mv "$1" "$1-$TS" > /dev/null 2>&1
	unset TS
}

_snapshot_if_diff() {
	maybe_echo "_snapshot_if_diff()"
	if [ -z "$2" ]; then
		echo "_snapshot_if_diff(): ERROR: nothing to diff"
		return 1
	fi
	if ! diff -EBq "$1" "$2" &>/dev/null; then
		echo "... writing $1"
		_rename_with_timestamp "$1"
		cat "$2" > "$1"
		return 0
	fi
	return 1
}

_a_newer_than_b() {
	maybe_echo "_a_newer_than_b()"
	A=$(date -r "$1" "+%s")
	B=$(date -r "$2" "+%s")
	[ "$A" -gt "$B" ]
}

# shellcheck disable=SC2317
_prepend_section_in_file() {
	maybe_echo "_prepend_section_in_file()"
	_SECTION="$1"
	_FILE="$2"
	_SECTION_READ=$(awk '/BEGIN_SHELLRC/,/END_SHELLRC/{print $0}' "$_FILE")
	if [ -z "$_SECTION_READ" ]; then
		printf '%s\n%s\n' "$_SECTION" "$(cat "$_FILE")" > "$_FILE"
	fi
	unset _SECTION _FILE _SECTION_READ
}

# shellcheck disable=SC2317
_append_section_in_file() {
	maybe_echo "_append_section_in_file()"
	_SECTION="$1"
	_FILE="$2"
	_SECTION_READ=$(awk '/BEGIN_SHELLRC/,/END_SHELLRC/{print $0}' "$_FILE")
	if [ -z "$_SECTION_READ" ]; then
		printf '%s\n%s\n' "$(cat "$_FILE")" "$_SECTION" > "$_FILE"
	fi
	unset _SECTION _FILE _SECTION_READ
}

# shellcheck disable=SC2317
_update_section_in_file() {
	maybe_echo "_update_section_in_file()"
	_SECTION="$1"
	_FILE="$2"
	# Read current from disk
	_SECTION_READ=$(awk '/BEGIN_SHELLRC/,/END_SHELLRC/{print $0}' "$_FILE")
	# Abort if: no SHELLRC section is found
	if [ -z "$_SECTION_READ" ]; then
		maybe_echo "... $_FILE has no SHELLRC section. Aborting."
		return 0
	# Abort if: SHELLRC section is unchanged
	elif [ "$_SECTION_READ" = "$_SECTION" ]; then
		maybe_echo "... SHELLRC section in $_FILE is unchanged."
		return 0
	# Abort if: ssh config is newer than .shellrc
	elif _a_newer_than_b "$_FILE" "$(_get_shellrc_file)"; then
		maybe_echo "... SHELLRC section in $_FILE has recent edits. Aborting."
		return 0
	fi
	maybe_echo "... updating SHELLRC section in $_FILE"
	# Finally replace ssh config section with our section
	_TEMPFILE="$(mktemp)"
	awk '
		BEGIN { sv=ARGV[1]; delete ARGV[1] }
		/BEGIN_SHELLRC/ { print sv; section=1; next }
		/END_SHELLRC/ { section=0; next }
		section {next}
		{print}
	' "$_SECTION" "$_FILE" > "$_TEMPFILE" && mv "$_TEMPFILE" "$_FILE"
	unset _SECTION _SECTION_READ _FILE _TEMPFILE
}

_get_shellrc_file() {
	SHELLRC_FILE=~/.shellrc
	if command -v perl > /dev/null; then
		SHELLRC_FILE=$(perl -MCwd -le 'print Cwd::abs_path(shift)' "$SHELLRC_FILE")
	elif command -v realpath > /dev/null; then
		SHELLRC_FILE=$(realpath "$SHELLRC_FILE")
	else
		SHELLRC_FILE=$(readlink -f "$SHELLRC_FILE")
	fi
	printf "%s" "$SHELLRC_FILE"
	unset SHELLRC_FILE
}

update_shellrc() {
	# https://stackoverflow.com/questions/24118224/how-to-make-asynchronous-function-calls-in-shell-scripts
	F=$(mktemp)
	# utc seconds: date "+%s"
	# file modfied time: date -r <filename> "+%s"
	# Find real .shellrc file if symlinked
	SHELLRC_FILE=$(_get_shellrc_file)
	if ! curl -s -L -o "$F" https://raw.githubusercontent.com/tmslnz/shellrc/main/shellrc; then
		echo "... curl error"
		return 1
	fi
	if ! diff -EBq "$SHELLRC_FILE" "$F" &>/dev/null; then
		echo "... writing $SHELLRC_FILE"
		_rename_with_timestamp "$SHELLRC_FILE"
		cat "$F" > "$SHELLRC_FILE"
		# shellcheck disable=SC1090
		. "$SHELLRC_FILE"
	else
		echo "... no updates available"
	fi
	unset F SHELLRC_FILE
}

setup_sh() {
	is_bash || is_zsh && return 0
	maybe_echo "setup_sh()"
	FILES="$HOME/.profile"
	for F in ${FILES}; do
		if [ -f "$F" ] && grep -Fq '[ -f ~/.shellrc ]' "$F"; then
			continue
		else
			[ -f "$F" ] && _rename_with_timestamp "$F"
			tee "$F" <<-EOF >/dev/null
				#!/usr/bin/env sh
				[ -f ~/.shellrc ] && source ~/.shellrc
				EOF
		fi
	done
	unset FILES F
}

setup_bash() {
	is_bash || return 0
	maybe_echo "setup_bash()"
	FILES=("$HOME/.bash_profile" "$HOME/.bashrc")
	for F in "${FILES[@]}"; do
		if [ -f "$F" ] && grep -Fq '[ -f ~/.shellrc ]' "$F"; then
			continue
		else
			[ -f "$F" ] && _rename_with_timestamp "$F"
			tee "$F" <<-EOF >/dev/null
				#!/usr/bin/env bash
				[ -f /etc/bashrc ] && /etc/bashrc
				[ -f ~/.shellrc ] && source ~/.shellrc
				EOF
		fi
	done
	unset FILES F
}

enable_homebrew_bash() {
	command -v brew > /dev/null || return 0
	BREW_PREFIX=$(brew --prefix)
	grep -Fxq "$BREW_PREFIX/bin/bash" /etc/shells && return 0
	[ -f "$BREW_PREFIX/bin/bash" ] || return 0
	maybe_echo "enable_homebrew_bash()"
	echo "$BREW_PREFIX/bin/bash" | sudo tee -a /etc/shells
	sudo chsh -s "$BREW_PREFIX/bin/bash"
	cat /etc/shells
	unset BREW_PREFIX
}

disable_homebrew_bash() {
	command -v brew > /dev/null || return 0
	grep -Fxq "$(brew --prefix)/bin/bash" /etc/shells && return 0
	maybe_echo "disable_homebrew_bash()"
	sudo chsh -s /bin/bash
}

setup_zsh() {
	is_zsh || return 0
	maybe_echo "setup_zsh()"
	# FILES=("$HOME/.zprofile" "$HOME/.zshrc")
	FILES=("$HOME/.zshrc") # Seems to be setting only from here
	for F in "${FILES[@]}"; do
		if [ -f "$F" ] && grep -Fq '[ -f ~/.shellrc ]' "$F"; then
			continue
		else
			[ -f "$F" ] && _rename_with_timestamp "$F"
			tee "$F" <<-EOF >/dev/null
				#!/usr/bin/env zsh
				[ -f ~/.shellrc ] && source ~/.shellrc
				EOF
		fi
	done
	unset FILES F
}

